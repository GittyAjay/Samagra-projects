{
  "name": "samagra-solar-sales-api",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "sh -c 'set -a; . ../.env; set +a; nitro dev'",
    "build": "sh -c 'set -a; . ../.env; set +a; prisma generate && prisma migrate deploy && nitro build'",
    "start": "sh -c 'set -a; . ../.env; set +a; node .output/server/index.mjs'",
    "prisma:generate": "prisma generate",
    "prisma:push": "sh -c 'set -a; . ../.env; set +a; prisma db push'"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "firebase-admin": "^13.7.0",
    "nitro": "^3.0.0-beta.4",
    "nodemailer": "^8.0.4",
    "prisma": "6.19.2"
  }
}
